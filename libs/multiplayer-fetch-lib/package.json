{
    "name": "@multiplayer/fetch",
    "version": "0.0.1",
    "description": "Multiplayer fetch library",
    "main": "dist/index.js",
    "engines": {
        "node": ">=18",
        "npm": ">=8"
    },
    "scripts": {
