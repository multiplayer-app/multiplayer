{
    "name": "@multiplayer/logger",
    "version": "0.0.1",
    "description": "Multiplayer logger library",
    "main": "dist/index.js",
    "engines": {
        "node": ">=18",
        "npm": ">=8"
    },
    "scripts": {
        "lint": "eslint src/**/*.ts --config ../../eslint.config.js",
