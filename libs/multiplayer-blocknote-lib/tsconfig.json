{
  "compilerOptions": {
    "target": "ES2020",
    "baseUrl": ".",
    "useDefineForClassFields": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "strict": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noEmit": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "outDir": "./dist/",
    "rootDir": "./src/",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "skipLibCheck": true,
    "paths": {
      "react": ["./node_modules/@types/react"]
    },
    "types": ["vite-plugin-svgr/client"]
  },
  "include": ["src"],
  "exclude": ["dist", "__tests__", "jest.config.js"]
}
