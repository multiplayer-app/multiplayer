{
  "name": "@multiplayer/monorepo",
  "version": "1.0.1-alpha.0",
  "description": "",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start:pm2": "bash ./scripts/start-pm2.sh",
    "stop:pm2": "bash ./scripts/stop-pm2.sh",
    "mongo-restore": "bash ./scripts/import-db-docker.sh",
    "mongo-export": "bash ./scripts/export-db-docker.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "prepare": "npx husky install",
    "create-invite-token": "tsc -p scripts/seed/create-invitation-token && node scripts/seed/create-invitation-token/dist/create-invitation-token.js",
    "seed-roles": "npm --prefix scripts/seed/seed-roles start",
    "seed-counter": "npm --prefix scripts/seed/counter start",
    "migrate:up": "cd ./migrations && npm install && npx migrate-mongo up",
    "migrate:down": "cd ./migrations && npm install && npx migrate-mongo down",
    "migrate:create": "cd ./migrations && npm install && npx migrate-mongo create"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/multiplayer-app/multiplayer-platform.git"
  },
  "author": "Multiplayer",
  "bugs": {
    "url": "https://github.com/multiplayer-app/multiplayer-platform/issues"
  },
  "homepage": "https://github.com/multiplayer-app/multiplayer-platform#readme",
  "dependencies": {
    "lerna": "7.1.3"
  },
  "devDependencies": {
    "turbo": "^2.8.20",
    "@commitlint/cli": "17.4.4",
    "@commitlint/config-conventional": "17.4.4",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "10.1.0",
    "husky": "9.1.5",
    "lint-staged": "13.1.2"
  },
  "resolutions": {
    "zod": "3.25.55"
  },
  "pnpm": {
    "overrides": {
      "@multiplayer/multiplayer-web-app>eslint": "^8.57.0"
    },
    "onlyBuiltDependencies": [
      "bcrypt",
      "mongodb-client-encryption"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
