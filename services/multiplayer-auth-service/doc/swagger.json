            }
          },
          "default": {
            "description": "unexpected error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/public/oauth-clients/{clientId}": {
      "get": {
        "operationId": "getPublicOauthClient",
        "summary": "Read OAuth client registration.",
        "tags": ["OAuth-Public"],
        "security": [{ "BearerRegistrationToken": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "clientId",
            "required": true,
            "schema": { "type": "string", "minLength": 24, "maxLength": 24 }
          }
        ],
        "responses": {
          "200": {
            "description": "OAuth client registration data.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OauthClientRegistrationData" }
              }
            }
          },
          "default": {
            "description": "unexpected error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "put": {
        "operationId": "updateOauthClient",
        "summary": "Update OAuth client registration.",
        "tags": ["OAuth-Public"],
        "security": [{ "BearerRegistrationToken": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "clientId",
            "required": true,
            "schema": { "type": "string", "minLength": 24, "maxLength": 24 }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OauthClientUpdatePayload" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated client registration data.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OauthClientRegistrationData" }
              }
            }
          },
          "default": {
            "description": "unexpected error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "delete": {
        "operationId": "deleteOauthClient",
        "summary": "Delete an OAuth client registration.",
        "tags": ["OAuth-Public"],
        "security": [{ "BearerRegistrationToken": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "clientId",
            "required": true,
            "schema": { "type": "string", "minLength": 24, "maxLength": 24 }
          }
        ],
        "responses": {
          "204": { "description": "Client deleted." },
          "default": {
            "description": "unexpected error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/public/oauth-clients/token": {
      "post": {
        "operationId": "exchangeToken",
        "summary": "Exchange an authorization code or refresh token for access/refresh tokens.",
        "tags": ["OAuth-Public"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TokenExchangePayload" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenExchangeResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid request (bad grant type, mismatched redirect_uri, invalid code_verifier).",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OauthError" } } }
          },
          "401": {
            "description": "Invalid or expired code/refresh token.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OauthError" } } }
          }
        }
      }
    },
    "/public/oauth-clients/token/revoke": {
      "post": {
        "operationId": "revokeToken",
        "summary": "Revoke an access token.",
        "tags": ["OAuth-Public"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RevokeTokenPayload" }
            }
          }
        },
        "responses": {
          "204": { "description": "Token revoked." },
          "default": {
            "description": "unexpected error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    }
  },
  "components": {
