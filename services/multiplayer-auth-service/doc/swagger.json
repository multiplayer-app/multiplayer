    "/oauth-clients/{clientId}": {
      "get": {
        "operationId": "getOauthClient",
        "summary": "Get OAuth client info (used by the authorize page).",
        "tags": ["OAuth-Clients"],
        "security": [{ "CookieAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "clientId",
            "required": true,
            "schema": { "type": "string", "minLength": 24, "maxLength": 24 },
            "description": "OAuth client ID."
          },
          {
            "in": "query",
            "name": "redirect_uri",
            "required": true,
            "schema": { "type": "string" },
            "description": "Redirect URI registered for this client."
          },
          {
            "in": "query",
            "name": "response_type",
            "required": true,
            "schema": { "type": "string", "enum": ["code"] },
            "description": "Must be 'code'."
          }
        ],
        "responses": {
          "200": {
            "description": "OAuth client info.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OauthClientInfo" }
              }
            }
          },
          "default": {
            "description": "unexpected error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/oauth-clients/{clientId}/authorize": {
      "post": {
        "operationId": "generateAuthCode",
        "summary": "Generate an authorization code for an OAuth client.",
        "tags": ["OAuth-Clients"],
        "security": [{ "CookieAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "clientId",
            "required": true,
            "schema": { "type": "string", "minLength": 24, "maxLength": 24 },
            "description": "OAuth client ID."
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GenerateAuthCodePayload" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authorization code (plain string).",
            "content": {
              "application/json": {
                "schema": { "type": "string", "example": "a1b2c3d4..." }
              }
            }
          },
          "default": {
            "description": "unexpected error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/public/oauth-clients": {
      "post": {
        "operationId": "registerOauthClient",
        "summary": "Register a new OAuth client (RFC 7591 dynamic registration).",
        "tags": ["OAuth-Public"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OauthClientRegistrationPayload" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registered client with credentials.",
