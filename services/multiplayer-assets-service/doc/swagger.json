{
  "openapi": "3.0.0",
  "info": {
    "title": "Multiplayer Assets Service",
    "version": "1.0.0",
    "description": "Assets management service for Multiplayer platform"
  },
  "servers": [
    {
      "url": "/v0/assets"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "description": "Returns the health status of the service",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "service": {
                      "type": "string",
                      "example": "multiplayer-assets-service"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/healthz": {
      "get": {
        "summary": "Health check (simple)",
        "description": "Returns a simple 'ok' response",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "ok"
                }
              }
            }
          }
        }
      }
    },
    "/workspaces/{workspaceId}/projects/{projectId}/debug-sessions/{debugSessionId}/notes/content": {
      "get": {
        "summary": "Get session note content with images",
        "description": "Retrieves session note content and generates images from rrweb events",
        "parameters": [
          {
            "name": "workspaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Workspace ID"
          },
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Project ID"
          },
          {
            "name": "debugSessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Debug session ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Session note content with image URLs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "content": {
                      "type": "object",
                      "description": "Session note content"
                    },
                    "imageUrls": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Array of presigned image URLs"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
