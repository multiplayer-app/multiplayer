{
  "name": "@multiplayer/git",
  "version": "0.0.1",
  "description": "Git service",
  "main": "./src/index.ts",
  "engines": {
    "node": ">=18",
    "npm": ">=8"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsc -w & nodemon --watch dist ./dist/index.js",
    "build": "npm run clean && npm run compile",
    "clean": "rm -rf ./dist",
    "compile": "tsc --build --force",
    "build:docker": "bash ../../scripts/docker-build.sh",
    "push:docker": "bash ../../scripts/docker-push.sh",
    "build:push:docker": "npm run build:docker && npm run push:docker",
    "octopus:release": "bash ../../scripts/octopus-release.sh",
    "multiplayer:release": "bash ../../scripts/multiplayer-release.sh",
    "lint": "eslint src/**/*.ts --config ../../eslint.config.js",
    "test": "env-cmd -f .env.test jest --forceExit"
  },
  "author": "Multiplayer",
  "dependencies": {
    "@linear/sdk": "11.0.0",
    "@multiplayer/auth": "0.0.1",
    "@multiplayer/apm": "0.0.1",
    "@multiplayer/amqp": "0.0.1",
    "@multiplayer/fetch": "0.0.1",
    "@multiplayer/logger": "0.0.1",
    "@multiplayer/mongo": "0.0.1",
    "@multiplayer/models": "0.0.1",
    "@multiplayer/redis": "0.0.1",
    "@multiplayer/types": "0.0.1",
    "@multiplayer/util": "0.0.1",
    "@multiplayer/util-shared": "0.0.1",
    "@octokit/app": "14.0.0",
    "@octokit/auth-app": "6.0.0",
    "@octokit/request": "9.2.2",
    "@octokit/rest": "20.0.1",
    "@slack/oauth": "3.0.4",
    "@slack/web-api": "7.12.0",
    "base64url": "3.0.1",
    "body-parser": "1.20.2",
    "cookie-parser": "1.4.6",
    "dotenv": "16.3.1",
    "express": "5.2.1",
    "express-jsdoc-swagger": "1.8.0",
    "express-session": "1.17.3",
    "joi": "17.10.0",
    "oauth": "0.10.0",
    "passport": "0.6.0",
    "passport-atlassian-oauth2": "2.1.0",
    "passport-github2": "0.1.12",
    "passport-gitlab2": "5.0.0",
    "passport-bitbucket-oauth2": "0.1.2",
    "restify-errors": "8.0.2"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@babel/preset-typescript": "7.28.5",
    "@types/body-parser": "1.19.2",
    "@types/cookie-parser": "1.4.3",
    "@types/cors": "2.8.13",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "@types/passport": "1.0.12",
    "@types/passport-github2": "1.2.5",
    "@types/restify-errors": "4.3.5",
    "axios": "1.8.4",
    "babel-jest": "30.3.0",
    "env-cmd": "10.1.0",
    "eslint": "10.1.0",
    "jest": "30.3.0",
    "jest-environment-node": "30.3.0",
    "nodemon": "3.1.14",
    "supertest": "6.3.3",
    "typescript": "6.0.2"
  },
  "overrides": {
    "passport-atlassian-oauth2": {
      "passport-oauth2": "1.8.0"
    },
    "passport-github2": {
      "passport-oauth2": "1.8.0"
    },
    "passport-gitlab2": {
      "passport-oauth2": "1.8.0"
    },
    "passport-bitbucket-oauth2": {
      "passport-oauth2": "1.8.0"
    }
  }
}
